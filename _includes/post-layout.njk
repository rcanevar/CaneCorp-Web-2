<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} — Canecorp</title>
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #f8f7f4; --bg2: #ffffff; --text: #1a1a18; --text2: #5a5a55;
      --accent: #1a4fa8; --accent2: #e8f0fc; --border: rgba(0,0,0,0.1); --radius: 12px;
    }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; }

    nav {
      background: var(--bg2); border-bottom: 1px solid var(--border);
      padding: 0 40px; display: flex; align-items: center; justify-content: space-between;
      height: 74px; position: sticky; top: 0; z-index: 100;
    }
    .logo { font-size: 32px; font-weight: 700; color: var(--accent); letter-spacing: -0.5px; border-bottom: 5px solid #000; text-decoration: none; }
    .logo span { font-size: 28px; color: var(--text); }
    nav ul { list-style: none; display: flex; gap: 32px; }
    nav ul li a { text-decoration: none; color: var(--text2); font-size: 14px; transition: color 0.2s; }
    nav ul li a:hover { color: var(--accent); }

    .post-hero {
      background: linear-gradient(135deg, #0f2d6b 0%, #1a4fa8 60%, #2563c4 100%);
      color: #fff; padding: 70px 40px 50px; text-align: center;
    }
    .post-hero .section-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 2px; color: #7db3ff; margin-bottom: 14px; }
    .post-hero h1 { font-size: clamp(24px, 4vw, 42px); font-weight: 700; letter-spacing: -0.5px; line-height: 1.2; max-width: 760px; margin: 0 auto 16px; }
    .post-hero .meta { font-size: 14px; color: rgba(255,255,255,0.65); margin-top: 12px; }

    .post-body { max-width: 760px; margin: 0 auto; padding: 60px 40px 80px; }
    .post-body h2 { font-size: 24px; font-weight: 700; margin: 36px 0 12px; color: var(--text); }
    .post-body h3 { font-size: 19px; font-weight: 600; margin: 28px 0 10px; }
    .post-body p { font-size: 16px; color: var(--text2); line-height: 1.8; margin-bottom: 20px; }
    .post-body ul, .post-body ol { padding-left: 24px; margin-bottom: 20px; color: var(--text2); font-size: 16px; line-height: 1.8; }
    .post-body li { margin-bottom: 6px; }
    .post-body strong { color: var(--text); }
    .post-body a { color: var(--accent); }
    .post-body blockquote { border-left: 4px solid var(--accent); padding: 12px 20px; background: var(--accent2); border-radius: 0 8px 8px 0; margin: 24px 0; color: var(--text2); font-style: italic; }
    .post-body img { max-width: 100%; border-radius: var(--radius); margin: 24px 0; }
    .post-body hr { border: none; border-top: 1px solid var(--border); margin: 40px 0; }

    .back-link { display: inline-flex; align-items: center; gap: 6px; color: var(--accent); font-size: 14px; font-weight: 600; text-decoration: none; margin-bottom: 36px; }
    .back-link:hover { text-decoration: underline; }

    footer { background: #0f2d6b; color: rgba(255,255,255,0.7); text-align: center; padding: 32px 40px; font-size: 13px; }
    footer strong { color: #fff; }

    @media (max-width: 700px) {
      nav ul { display: none; }
      .post-hero { padding: 50px 24px 40px; }
      .post-body { padding: 40px 24px 60px; }
    }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="logo">CANE<span>corp</span></a>
    <ul>
      <li><a href="/#servicios">Servicios</a></li>
      <li><a href="/#nosotros">Nosotros</a></li>
      <li><a href="/blog/">Blog</a></li>
      <li><a href="/#contacto">Contacto</a></li>
    </ul>
  </nav>

  <div class="post-hero">
    <p class="section-label">Blog</p>
    <h1>{{ title }}</h1>
    <p class="meta">{{ date | dateFormat }}</p>
  </div>

  <div class="post-body">
    <a href="/blog/" class="back-link">← Volver al blog</a>
    {{ content | safe }}
  </div>

  <footer>
    <p><strong>Canecorp</strong> — Servicios IT · SAP Business One · Argentina</p>
    <p style="margin-top:6px;">© 2025 Canecorp. Todos los derechos reservados.</p>
  </footer>

  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => { document.location.href = "/admin/"; });
        }
      });
    }
  </script>
</body>
</html>
